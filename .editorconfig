root = true

[*]
charset = utf-8
end_of_line = crlf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_size = 4

# Naming conventions
dotnet_naming_rule.interfaces_should_begin_with_i.symbols = interface_symbols
dotnet_naming_rule.interfaces_should_begin_with_i.style = prefix_with_i
dotnet_naming_rule.interfaces_should_begin_with_i.severity = warning

dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.prefix_with_i.required_prefix = I

# Language keywords over framework types
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# Expression-bodied members
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion

# var preferences
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# Braces
csharp_prefer_braces = when_multiline:suggestion

# Modifiers
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:warning

# Blank lines
dotnet_style_allow_multiple_blank_lines_experimental = false:warning

[*.{csproj,sln,props,targets}]
indent_size = 2
end_of_line = crlf
